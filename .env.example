# Budgets Around Me! — Backend Proxy Server
# Copy this to .env and fill in your values. NEVER commit .env to git.

# Your API keys (server-side only, never exposed to clients)
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Server config
PORT=3000
NODE_ENV=production

# Apple Sign In — your App ID (team + bundle)
APPLE_TEAM_ID=your_apple_team_id
APPLE_BUNDLE_ID=com.budgetaround.app

# JWT secret for server-issued tokens (generate with: openssl rand -hex 32)
JWT_SECRET=generate_a_random_64_char_string_here

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
