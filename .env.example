# Budgets Around Me! — Backend Proxy Server
# Copy this to .env and fill in your values. NEVER commit .env to git.

# Your API keys (server-side only, never exposed to clients)
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY_HERE
GOOGLE_PLACES_API_KEY=AIzaSyYOUR_GOOGLE_KEY_HERE

# Server config
PORT=3000
NODE_ENV=production

# Apple Sign In — your App ID (team + bundle)
APPLE_TEAM_ID=BADLYX9ZK2
APPLE_BUNDLE_ID=com.budgetaround.app

# JWT secret for server-issued tokens (generate a random 64-char string)
# You can generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60